-- 待辦事項表
-- 參考: prd.md Section 4.1

CREATE TABLE todos (
    id TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    due_date TEXT,
    is_completed INTEGER NOT NULL DEFAULT 0,
    type TEXT NOT NULL DEFAULT 'general',
    document_type TEXT,
    reminder_date TEXT,
    created_at INTEGER NOT NULL DEFAULT (cast(strftime('%s', 'now') as int))
) AS TodoRow;
